{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023", "dom"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": true,
    "types": ["node"]
  },
  "include": ["src/**/*.mjs", "src/**/*.d.ts", "tests/**/*.mjs", "tests/**/*.d.ts"]
}
